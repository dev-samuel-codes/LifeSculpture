rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
             && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
             && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isAllowedPostImage() {
      return request.resource != null
             && request.resource.size < 5 * 1024 * 1024
             && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }

    function isPublicPost(category, postId) {
      return firestore.exists(/databases/(default)/documents/$(category)/$(postId))
             && firestore.get(/databases/(default)/documents/$(category)/$(postId)).data.isPublic == true;
    }

    // Public image assets
    match /image/{file=**} {
      allow read: if true;
      allow write: if false;
    }

    // 게시물 이미지 경로
    match /post-images/{category}/{postId}/{fileName} {
      allow read: if isAdmin() || isPublicPost(category, postId);

      // 관리자만 업로드/삭제 가능하며 파일 타입과 용량은 Rules에서도 검증
      allow create, update: if isAdmin() && isAllowedPostImage();
      allow delete: if isAdmin();
    }

    // 나머지는 잠금
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
