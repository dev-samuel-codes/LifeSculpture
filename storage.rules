rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public image assets
    match /image/{file=**} {
      allow read: if true;
      allow write: if false;
    }

    // 게시물 이미지 경로
    match /post-images/{file=**} {
      // 누구나 읽기 가능 (공개 이미지)
      allow read: if true;

      // 관리자(내 UID)만 업로드/삭제 가능
      // 현재 UID: Bvik2Rv5HzatCW91UNjCuro0y8I3
      // 다른 사용자도 허용하려면 이 UID를 추가하거나 규칙을 수정하세요
      allow write: if request.auth != null
                   && request.auth.uid == "Bvik2Rv5HzatCW91UNjCuro0y8I3";
                   // 선택: 이미지 타입/용량 추가 제한
                   // && request.resource.contentType.matches('image/.*')
                   // && request.resource.size < 15 * 1024 * 1024
    }

    // 나머지는 잠금
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
