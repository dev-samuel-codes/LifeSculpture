{
  "name": "my-fullstack-app",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:rules && npm run test:env",
    "test:rules": "bash scripts/run-rules-tests.sh",
    "test:env": "npm run test:env --prefix frontend",
    "test:hosting": "firebase emulators:exec --only hosting --project demo-lifesculpture \"node --test tests/hosting/cache-headers.test.js\"",
    "start": "concurrently \"npm start --prefix frontend\" \"npm run start-backend\"",
    "start-backend": "cd server && node index.js",
    "build": "npm run build --prefix frontend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "concurrently": "^9.2.0",
    "firebase": "^12.14.0",
    "firebase-tools": "^15.20.0",
    "jest": "^30.4.2"
  }
}
