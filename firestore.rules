rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
             ((request.auth.token.keys().hasAny(["admin"]) &&
               request.auth.token.admin == true) ||
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"));
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function commentDocPath(cat, postId, commentId) {
      return /databases/$(database)/documents/$(cat)/$(postId)/comments/$(commentId);
    }

    function postDocPath(cat, postId) {
      return /databases/$(database)/documents/$(cat)/$(postId);
    }

    function postIndexDocPath(cat, postId) {
      return /databases/$(database)/documents/post_index/$(cat)/posts/$(postId);
    }

    function postLikeDocPath(cat, postId, uid) {
      return /databases/$(database)/documents/$(cat)/$(postId)/likes/$(uid);
    }

    function isPublicPost() {
      return resource.data.isPublic == true;
    }

    function isPublicPostAt(cat, postId) {
      let postPath = /databases/$(database)/documents/$(cat)/$(postId);
      return exists(postPath) && get(postPath).data.isPublic == true;
    }

    function canReadPostAt(cat, postId) {
      return isPublicPostAt(cat, postId) || isAdmin();
    }

    function hasMatchingCommentIdentity() {
      return request.resource.data.authorName == null &&
             request.resource.data.authorPhoto == null;
    }

    function isPostLikeAggregateUpdate(cat, postId, counterpartPath) {
      let membershipPath = postLikeDocPath(cat, postId, request.auth.uid);
      return isSignedIn() &&
             isPublicPost() &&
             resource.data.likeCount is int &&
             request.resource.data.likeCount is int &&
             request.resource.data.likeCount >= 0 &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount']) &&
             getAfter(counterpartPath).data.likeCount == request.resource.data.likeCount &&
             ((request.resource.data.likeCount == resource.data.likeCount + 1 &&
               !exists(membershipPath) &&
               existsAfter(membershipPath)) ||
              (request.resource.data.likeCount == resource.data.likeCount - 1 &&
               exists(membershipPath) &&
               !existsAfter(membershipPath)));
    }

    function isPostLikeMembershipCreate(cat, postId, likeUid) {
      let postPath = postDocPath(cat, postId);
      let indexPath = postIndexDocPath(cat, postId);
      return isSignedIn() &&
             likeUid == request.auth.uid &&
             exists(postPath) &&
             get(postPath).data.isPublic == true &&
             request.resource.data.keys().hasOnly(['createdAt']) &&
             request.resource.data.createdAt == request.time &&
             getAfter(postPath).data.likeCount == get(postPath).data.likeCount + 1 &&
             getAfter(indexPath).data.likeCount == getAfter(postPath).data.likeCount;
    }

    function isPostLikeMembershipDelete(cat, postId, likeUid) {
      let postPath = postDocPath(cat, postId);
      let indexPath = postIndexDocPath(cat, postId);
      return isSignedIn() &&
             likeUid == request.auth.uid &&
             exists(postPath) &&
             get(postPath).data.isPublic == true &&
             getAfter(postPath).data.likeCount == get(postPath).data.likeCount - 1 &&
             getAfter(postPath).data.likeCount >= 0 &&
             getAfter(indexPath).data.likeCount == getAfter(postPath).data.likeCount;
    }

    function hasValidCommentContent() {
      return request.resource.data.content is string &&
             request.resource.data.content.size() > 0 &&
             request.resource.data.content.size() <= 2000;
    }

    function isValidParent(cat, postId) {
      return request.resource.data.parentId == null ||
             (exists(commentDocPath(cat, postId, request.resource.data.parentId)) &&
              get(commentDocPath(cat, postId, request.resource.data.parentId)).data.parentId == null);
    }

    function isValidCommentCreate(cat, postId) {
      return request.resource.data.keys().hasOnly([
               'authorId',
               'authorName',
               'authorPhoto',
               'content',
               'parentId',
               'createdAt',
               'updatedAt'
             ]) &&
             request.resource.data.authorId is string &&
             (request.resource.data.authorName == null || request.resource.data.authorName is string) &&
             (request.resource.data.authorPhoto == null || request.resource.data.authorPhoto is string) &&
             hasValidCommentContent() &&
             (request.resource.data.parentId == null || request.resource.data.parentId is string) &&
             request.resource.data.createdAt == request.time &&
             request.resource.data.updatedAt == request.time &&
             hasMatchingCommentIdentity() &&
             isValidParent(cat, postId);
    }

    function isValidCommentUpdate(cat, postId) {
      return request.resource.data.keys().hasOnly([
               'authorId',
               'authorName',
               'authorPhoto',
               'content',
               'parentId',
               'createdAt',
               'updatedAt'
             ]) &&
             request.resource.data.authorId == resource.data.authorId &&
             request.resource.data.authorName == resource.data.authorName &&
             request.resource.data.authorPhoto == resource.data.authorPhoto &&
             request.resource.data.parentId == resource.data.parentId &&
             request.resource.data.createdAt == resource.data.createdAt &&
             request.resource.data.updatedAt == request.time &&
             hasValidCommentContent() &&
             isValidParent(cat, postId);
    }

    function canDeleteComment(cat, postId) {
      return isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        (resource.data.parentId != null &&
         get(commentDocPath(cat, postId, resource.data.parentId)).data.authorId == request.auth.uid)
      );
    }

    function canDeleteCommentLike(cat, postId, commentId, likeUid) {
      let comment = get(commentDocPath(cat, postId, commentId));
      return isSignedIn() && (
        likeUid == request.auth.uid ||
        comment.data.authorId == request.auth.uid ||
        (comment.data.parentId != null &&
         get(commentDocPath(cat, postId, comment.data.parentId)).data.authorId == request.auth.uid)
      );
    }

    match /blog/{postId} {
      allow read: if isPublicPost() || isAdmin();
      allow write: if isAdmin();
      allow update: if isPostLikeAggregateUpdate(
        "blog",
        postId,
        postIndexDocPath("blog", postId)
      );

      match /likes/{likeUid} {
        allow get: if isAdmin() || (isSignedIn() && likeUid == request.auth.uid);
        allow list: if isAdmin();
        allow create: if isAdmin() || isPostLikeMembershipCreate("blog", postId, likeUid);
        allow delete: if isAdmin() || isPostLikeMembershipDelete("blog", postId, likeUid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if canReadPostAt("blog", postId);
        allow create: if isAdmin() ||
                       (isPublicPostAt("blog", postId) &&
                        isSignedIn() &&
                        request.resource.data.authorId == request.auth.uid &&
                        isValidCommentCreate("blog", postId));
        allow update: if (isPublicPostAt("blog", postId) &&
                         isSignedIn() &&
                         resource.data.authorId == request.auth.uid &&
                         isValidCommentUpdate("blog", postId)) || isAdmin();
        allow delete: if (isPublicPostAt("blog", postId) &&
                          canDeleteComment("blog", postId)) || isAdmin();

        match /likes/{likeUid} {
          allow read: if canReadPostAt("blog", postId);
          allow create: if isAdmin() ||
                         (isPublicPostAt("blog", postId) &&
                          isSignedIn() &&
                          exists(commentDocPath("blog", postId, commentId)) &&
                          likeUid == request.auth.uid &&
                          request.resource.data.keys().hasOnly(['createdAt']) &&
                          request.resource.data.createdAt == request.time);
          allow delete: if isAdmin() ||
                         (isPublicPostAt("blog", postId) &&
                          canDeleteCommentLike("blog", postId, commentId, likeUid));
          allow update: if false;
        }
      }
    }

    match /study/{postId} {
      allow read: if isPublicPost() || isAdmin();
      allow write: if isAdmin();
      allow update: if isPostLikeAggregateUpdate(
        "study",
        postId,
        postIndexDocPath("study", postId)
      );

      match /likes/{likeUid} {
        allow get: if isAdmin() || (isSignedIn() && likeUid == request.auth.uid);
        allow list: if isAdmin();
        allow create: if isAdmin() || isPostLikeMembershipCreate("study", postId, likeUid);
        allow delete: if isAdmin() || isPostLikeMembershipDelete("study", postId, likeUid);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if canReadPostAt("study", postId);
        allow create: if isAdmin() ||
                       (isPublicPostAt("study", postId) &&
                        isSignedIn() &&
                        request.resource.data.authorId == request.auth.uid &&
                        isValidCommentCreate("study", postId));
        allow update: if (isPublicPostAt("study", postId) &&
                         isSignedIn() &&
                         resource.data.authorId == request.auth.uid &&
                         isValidCommentUpdate("study", postId)) || isAdmin();
        allow delete: if (isPublicPostAt("study", postId) &&
                          canDeleteComment("study", postId)) || isAdmin();

        match /likes/{likeUid} {
          allow read: if canReadPostAt("study", postId);
          allow create: if isAdmin() ||
                         (isPublicPostAt("study", postId) &&
                          isSignedIn() &&
                          exists(commentDocPath("study", postId, commentId)) &&
                          likeUid == request.auth.uid &&
                          request.resource.data.keys().hasOnly(['createdAt']) &&
                          request.resource.data.createdAt == request.time);
          allow delete: if isAdmin() ||
                         (isPublicPostAt("study", postId) &&
                          canDeleteCommentLike("study", postId, commentId, likeUid));
          allow update: if false;
        }
      }
    }

    match /users/{uid} {
      allow read, write: if isAdmin();
    }

    match /post_index/{category}/posts/{postId} {
      allow read: if isPublicPost() || isAdmin();
      allow write: if isAdmin();
      allow update: if (category == "blog" || category == "study") &&
                       isPostLikeAggregateUpdate(
                         category,
                         postId,
                         postDocPath(category, postId)
                       );
    }

    match /post_filters/{category} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
